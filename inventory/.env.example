# Supabase — จาก Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ใช้เฉพาะฝั่ง server / สคริปต์ seed / ปุ่ม Sync เท่านั้น — ห้าม commit ค่าจริง
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ลิงก์ดาวน์โหลดตรงของไฟล์ Excel บน OneDrive (ปุ่ม "Sync ข้อมูล" ใช้ดึงมาอ่าน)
# วิธีได้ลิงก์: OneDrive > แชร์ไฟล์ > Copy link > เติม "&download=1" ท้ายลิงก์ (ดู UPDATE.md)
ONEDRIVE_XLSB_URL=

# ตั้งค่าธุรกิจ
NEXT_PUBLIC_TIMEZONE=Asia/Bangkok
DEFAULT_LEAD_TIME_DAYS=14
NEAR_EXPIRY_DAYS=90
